<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>AI PhГўn TГӯch Doanh Thu</title>

<style>

body{
font-family: Arial;
background: url("https://i.ibb.co/h1tS5qs0/25ecc83e-010d-4d31-8011-d02e7bd20c52.jpg") center/cover no-repeat fixed;
margin:0;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.chat{
width:600px;
height:80vh;
background:white;
border-radius:10px;
display:flex;
flex-direction:column;
overflow:hidden;
}

.messages{
flex:1;
overflow-y:auto;
padding:15px;
background:#f1f5f9;
}

.msg{
margin-bottom:10px;
padding:10px 14px;
border-radius:8px;
max-width:80%;
white-space:pre-line;
}

.user{
background:#3b82f6;
color:white;
margin-left:auto;
}

.bot{
background:#e2e8f0;
}

.input{
display:flex;
border-top:1px solid #ddd;
}

textarea{
flex:1;
border:none;
padding:10px;
resize:none;
height:60px;
font-size:14px;
}

button{
width:100px;
border:none;
background:#22c55e;
color:white;
font-weight:bold;
cursor:pointer;
}

</style>
</head>

<body>

<div class="chat">

<div class="messages" id="messages"></div>

<div class="input">
<textarea id="input" placeholder="DГЎn bГЎo cГЎo doanh thu vГ o Д‘Гўy..."></textarea>
<button onclick="send()">Gб»ӯi</button>
</div>

</div>

<script>

const messages=document.getElementById("messages");
const input=document.getElementById("input");
input.addEventListener("keydown", function(e){
if(e.key === "Enter" && !e.shiftKey){
e.preventDefault(); // khГҙng xuб»‘ng dГІng
send(); // gб»ӯi tin nhбәҜn
}
});

function addMsg(text,type){
let div=document.createElement("div");
div.className="msg "+type;
div.textContent=text;
messages.appendChild(div);
messages.scrollTop=messages.scrollHeight;
}

function phanTichDoanhThu(text){

let nuoc10=0,tien10=0;
let comboNuoc10=0;
let nuoc12=0,tien12=0;
let nuoc15=0,tien15=0;
let nuoc18=0,tien18=0;

let myNuoc=0,tienMyNuoc=0;
let myXao=0,tienMyXao=0;

let kimbap=0,tienKimbap=0;
let xucxich=0,tienXucxich=0;
let trung=0,tienTrung=0;
let kem=0,tienKem=0;
let snack=0,tienSnack=0;
let thuoc=0,tienThuoc=0;

let lines=text.split("\n");
let tongBaoCao=0;

for(let line of lines){

let tongMatch=line.match(/Tб»•ng\s*cб»ҷng\s*([\d,]+)/i);
if(tongMatch){
tongBaoCao=parseInt(tongMatch[1].replace(/,/g,""));
}

if(!line.includes("Tб»•ng cб»ҷng:")) continue;

let match=line.match(/Tб»•ng cб»ҷng:\s*(.*?)\s+(\d+)\s+([\d,]+)/i);
if(!match) continue;

let ten=match[1].toUpperCase();
let soLuong=parseInt(match[2]);
let tien=parseInt(match[3].replace(/,/g,""));

let gia=Math.round(tien/soLuong);


// ===== NЖҜб»ҡC =====
if(/STING|PEPSI|COCA|COCA COLA|MIRINDA|SPRITE|AQUA|REVIVE|RIVIVE|ROCK|O LONG|OLONG|TRA|TRГҖ|COZY|SUA|Sб»®A|NUTRI/i.test(ten)){

if(gia<=10000){

nuoc10+=soLuong;
tien10+=tien;

// chб»ү tГӯnh combo cho sting vГ ng, pepsi, aqua
if(/STING VANG|PEPSI|AQUA/i.test(ten)){

let chaiTinhTien = Math.round(tien/10000);
let chaiCombo = soLuong - chaiTinhTien;

if(chaiCombo>0){
comboNuoc10 += chaiCombo;
}

}

}
else if(gia<=12000){nuoc12+=soLuong;tien12+=tien;}
else if(gia<=15000){nuoc15+=soLuong;tien15+=tien;}
else{nuoc18+=soLuong;tien18+=tien;}

}


// ===== Mб»І =====
else if(ten.includes("MY") || ten.includes("Mб»І")){

if(ten.includes("XAO")){
myXao+=soLuong;
tienMyXao+=soLuong*20000;
}else{
myNuoc+=soLuong;
tienMyNuoc+=soLuong*10000;
}

// trб»©ng kГЁm mб»і
if(/TRUNG|TRб»ЁNG|OP LA|б»җP LA|LUOT|LUб»ҳC/i.test(ten)){
trung+=soLuong;
tienTrung+=soLuong*10000;
}

// xГәc xГӯch kГЁm mб»і
if(/XUC XICH|XГҡC XГҚCH/i.test(ten)){
xucxich+=soLuong;
tienXucxich+=soLuong*10000;
}

}


// ===== TRб»ЁNG RIГҠNG =====
else if(/TRUNG|TRб»ЁNG|OP LA|б»җP LA|LUOT|LUб»ҳC/i.test(ten)){
trung+=soLuong;
tienTrung+=soLuong*10000;
}


// ===== KIMBAP =====
else if(ten.includes("KIMBAP")){
kimbap+=soLuong;
tienKimbap+=tien;
}


// ===== XГҡC XГҚCH =====
else if(/XUC XICH|XГҡC XГҚCH/i.test(ten)){
xucxich+=soLuong;
tienXucxich+=tien;
}


// ===== KEM =====
else if(ten.includes("KEM")){
kem+=soLuong;
tienKem+=tien;
}


// ===== SNACK =====
else if(/BIM|SNACK/i.test(ten)){
snack+=soLuong;
tienSnack+=tien;
}


// ===== THUб»җC =====
else if(/THUOC|THUб»җC/i.test(ten)){
thuoc+=soLuong;
tienThuoc+=tien;
}

}

let tongMy = myNuoc + myXao;
let tienTongMy = tienMyNuoc + tienMyXao;

let tongAI=
tien10+
tien12+
tien15+
tien18+
tienMyNuoc+
tienMyXao+
tienKimbap+
tienXucxich+
tienTrung+
tienKem+
tienSnack+
tienThuoc;

let tong = tongBaoCao || tongAI;

let kiemTra="";

if(tongBaoCao && tongBaoCao!==tongAI){
kiemTra=`вҡ пёҸ AI phГЎt hiб»Үn tб»•ng bГЎo cГЎo sai
рҹ“„ Tб»•ng bГЎo cГЎo: ${tongBaoCao.toLocaleString()} Д‘
рҹӨ– AI tГӯnh lбәЎi: ${tongAI.toLocaleString()} Д‘

`;
}

return `${kiemTra}рҹ“Ҡ PHГӮN TГҚCH DOANH THU

рҹҘӨ NЖ°б»ӣc 10k: ${nuoc10} mГіn - ${tien10.toLocaleString()} Д‘
рҹҘӨ NЖ°б»ӣc 12k: ${nuoc12} mГіn - ${tien12.toLocaleString()} Д‘
рҹҘӨ NЖ°б»ӣc 15k: ${nuoc15} mГіn - ${tien15.toLocaleString()} Д‘
рҹҘӨ NЖ°б»ӣc 18k: ${nuoc18} mГіn - ${tien18.toLocaleString()} Д‘

рҹҚң Mб»і nЖ°б»ӣc: ${myNuoc} mГіn - ${tienMyNuoc.toLocaleString()} Д‘
рҹҚң Mб»і xГ o: ${myXao} mГіn - ${tienMyXao.toLocaleString()} Д‘
рҹҚң Tб»•ng mб»і: ${tongMy} mГіn - ${tienTongMy.toLocaleString()} Д‘

рҹҚҷ Kimbap: ${kimbap} mГіn - ${tienKimbap.toLocaleString()} Д‘
рҹҢӯ XГәc xГӯch: ${xucxich} mГіn - ${tienXucxich.toLocaleString()} Д‘
рҹҘҡ Trб»©ng: ${trung} mГіn - ${tienTrung.toLocaleString()} Д‘
рҹҚҰ Kem: ${kem} mГіn - ${tienKem.toLocaleString()} Д‘
рҹҚҹ Snack/Bim: ${snack} mГіn - ${tienSnack.toLocaleString()} Д‘

рҹҡ¬ Thuб»‘c lГЎ: ${thuoc} mГіn - ${tienThuoc.toLocaleString()} Д‘

рҹҺҒ NЖ°б»ӣc 10k 0Д‘ Combo: ${comboNuoc10} chai

рҹ’° Tб»•ng doanh thu: ${tong.toLocaleString()} Д‘`;

}

function send(){

let text=input.value.trim();
if(!text) return;

addMsg(text,"user");

let result=phanTichDoanhThu(text);

setTimeout(()=>{
addMsg(result,"bot");
},500);

input.value="";

}

</script>

</body>
</html>
